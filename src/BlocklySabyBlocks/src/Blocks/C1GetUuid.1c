Функция block_c1_get_uuid_execute(block_type, node, path, context, block_context)
	value_node = block_c1_get_uuid_get_value_node(node);
	value = block_execute_all_next(value_node, path + "." + "value", context, block_context);
	Возврат Строка(value.УникальныйИдентификатор());
КонецФункции	

Функция block_c1_get_uuid_get_value_node(node)
	Возврат Root.ВычислитьВыражениеXpath("./b:value", node, размыватель).ПолучитьСледующий();	
КонецФункции	
