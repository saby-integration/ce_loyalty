
&НаКлиенте
Процедура Saby_ПоискКартыЛояльностиНажатие_Комманда(Элемент) Экспорт
	СтандартнаяОбработка	= Ложь;
	Saby_ОткрытьФормуПоискКартыЛояльности(Элемент, СтандартнаяОбработка);
КонецПроцедуры

&НаСервере
Процедура Saby_СоздатьЭлементыУправленияФормы()
	Saby_ФормаСервер.СоздатьКнопкуОткрытияФормыПоискаКартыИНазначитьКоманды(ЭтаФорма, "ГруппаИтоги", "СтраницыСуммаСкидки");
КонецПроцедуры

&НаКлиенте
Процедура Saby_ОбработатьОтветНаВопросОПересчётеСкидок(Результат, Параметры) Экспорт
	Если Результат = КодВозвратаДиалога.Да Тогда
		Saby_НазначитьАвтоматическиеСкидкиКлиент(Неопределено, Неопределено);
		ПоказатьОповещениеПользователя("Скидки успешно расчитаны",,,БиблиотекаКартинок.Успешно32,СтатусОповещенияПользователя.Важное,);
		Если Параметры.Команда.Имя = "ОплатитьПодарочнымСертификатом" Тогда
			ОплатитьПодарочнымСертификатом(Параметры.Команда);
		ИначеЕсли Параметры.Команда.Имя = "ОплатитьПлатежнойКартой" Тогда
			ОплатитьПлатежнойКартой(Параметры.Команда)
		ИначеЕсли Параметры.Команда.Имя = "СмешаннаяОплата" Тогда
			СмешаннаяОплата(Параметры.Команда)
		ИначеЕсли Параметры.Команда.Имя = "ОплатитьНаличными" Тогда
			ОплатитьНаличными(Параметры.Команда)
		КонецЕсли;
	Иначе
		ЭтотОбъект.Доступность = Истина;
	КонецЕсли;
КонецПроцедуры

&НаСервере
Функция Saby_ПолучитьОрганизацию() Экспорт
	Возврат Saby_Сервисы_Сервер.ПолучитьОрганизацию(ЭтаФорма);
КонецФункции

&НаСервере
Функция Saby_ПолучитьМагазин() Экспорт
	Возврат "";
КонецФункции

&НаСервере
Функция Saby_ПолучитьСклад() Экспорт
	Возврат Объект.Склад;
КонецФункции

